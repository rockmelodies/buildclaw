# BuildClaw backend environment example
#
# Copy to `.env` and adjust values for your deployment target.

# Optional alternative config file path.
# BUILDCLAW_CONFIG=/opt/buildclaw/backend/config.yaml

# Optional dotenv file override.
# BUILDCLAW_ENV_FILE=/opt/buildclaw/backend/.env

# Server bind configuration.
BUILDCLAW_ADDR=0.0.0.0
BUILDCLAW_PORT=8080

# Persistent workspace directory.
# BUILDCLAW_WORKSPACE=/var/lib/buildclaw/workspace
